   618     1 # Script: VolumeWhenStarted
   619     2 #
   620     3 # The adjusted volume free is proportional to the volume used space.
   621     4 # This keeps the zones sized relative to each other.
   622     5 # A 25% full disk will only utilize 25% of the disk free space.
   623     6 # Round up blocks are sized using this value now.
   624     7 #
   625     8 SetVariable(VolumeFreeAdj, (VolumeFree * (VolumeUsed / VolumeSize)))
   626     9 #
   627    10 # This keeps your MFT location from being insanely low on the disk.
   628    11 SetVariable(MftLocation, RoundUp(VolumeUsed * MftPerDev, VolumeSize * VolumeRoundUpLarge)) 
   629    12 
   630    13 SetVariable(ZoneStatisticsReport, "")
   631    14 SetVariable(ZoneListByLine, 		"Volume !VolumeLabel! started.
   632    15 ")
   633    16 SetVariable(ZoneStepByLine, 		"Initialize.
   634    17 ")
   635    18 SetVariable(ZoneStatisticsDetail, 	"")
   636    19 
