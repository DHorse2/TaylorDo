  3096     1 # Script: VolumeWhenStarted
  3097     2 #
  3098     3 # The adjusted volume free is proportional to the volume used space.
  3099     4 # This keeps the zones sized relative to each other.
  3100     5 # A 25% full disk will only utilize 25% of the disk free space.
  3101     6 # Round up blocks are sized using this value now.
  3102     7 #
  3103     8 SetVariable(VolumeFreeAdj, (VolumeFree * (VolumeUsed / VolumeSize)))
  3104     9 #
  3105    10 # This keeps your MFT location from being insanely low on the disk.
  3106    11 SetVariable(MftLocation, RoundUp(VolumeUsed * MftPerDev, VolumeSize * VolumeRoundUpLarge)) 
  3107    12 
  3108    13 SetVariable(ZoneStatisticsReport, "")
  3109    14 SetVariable(ZoneListByLine, 		"Volume !VolumeLabel! started.
  3110    15 ")
